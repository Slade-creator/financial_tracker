<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#00000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="0dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="@drawable/bg_glass_card_sm">

        <View
            android:id="@+id/statusIndicator"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="14dp"
            android:background="#00FFD1"/>

        <!-- Transaction details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Row 1: Type label + Amount -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="3dp">

                <!-- INCOME / EXPENSE label — color set from adapter -->
                <TextView
                    android:id="@+id/tvTransactionType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/income"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:textColor="#00FFD1"
                    android:fontFamily="@font/plus_jakarta_sans_medium"/>

                <!-- Amount — color set from adapter -->
                <TextView
                    android:id="@+id/tvAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/k0_00"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#00FFD1"
                    android:fontFamily="@font/plus_jakarta_sans_bold"/>
            </LinearLayout>

            <!-- Row 2: Category -->
            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/membership_fee"
                android:textSize="13sp"
                android:textColor="#CCFFFFFF"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:layout_marginTop="2dp"/>

            <!-- Row 3: Member name (hidden when empty via adapter) -->
            <TextView
                android:id="@+id/tvMemberName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/member_elton_chiwala"
                android:textSize="11sp"
                android:textColor="#4DFFFFFF"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:layout_marginTop="2dp"/>

            <!-- Row 4: Date + Payment method -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/_15_jan_2026"
                    android:textSize="11sp"
                    android:textColor="#4DFFFFFF"
                    android:fontFamily="@font/plus_jakarta_sans_medium"/>

                <!-- Payment method badge -->
                <TextView
                    android:id="@+id/tvPaymentMethod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cash"
                    android:textSize="10sp"
                    android:textColor="#4DFFFFFF"
                    android:background="@drawable/bg_count_badge"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:fontFamily="@font/plus_jakarta_sans_medium"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>