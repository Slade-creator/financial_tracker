<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_dashboard">

    <!-- Dashboard ─────────────────────────────────────────────────── -->
    <fragment
        android:id="@+id/nav_dashboard"
        android:name="com.studentassoc.financialtracker.View.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <!-- Export ────────────────────────────────────────────────────── -->
    <fragment
        android:id="@+id/nav_export"
        android:name="com.studentassoc.financialtracker.View.ExportBottomSheet"
        android:label="Export"
        tools:layout="@layout/fragment_export" />

    <!-- Reports (Weekly + Term ViewPager) ─────────────────────────── -->
    <fragment
        android:id="@+id/nav_reports"
        android:name="com.studentassoc.financialtracker.View.ReportsFragment"
        android:label="Reports"
        tools:layout="@layout/fragment_reports" />

    <!-- AI Insights ────────────────────────────────────────────────── -->
    <fragment
        android:id="@+id/nav_ai_insights"
        android:name="com.studentassoc.financialtracker.View.AIInsightsFragment"
        android:label="AI Insights"
        tools:layout="@layout/fragment_ai_insights" />

    <!-- Backup & Sync ─────────────────────────────────────────────── -->
    <fragment
        android:id="@+id/nav_backup"
        android:name="com.studentassoc.financialtracker.View.BackupFragment"
        android:label="Backup"
        tools:layout="@layout/fragment_backup" />

    <!-- Settings ──────────────────────────────────────────────────── -->
    <fragment
        android:id="@+id/nav_settings"
        android:name="com.studentassoc.financialtracker.View.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>