<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvSetupPinTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/setup_pin_title_new"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSetupPinSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/setup_pin_subtitle_new"
        android:textSize="14sp"
        android:textColor="#666666"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSetupPinTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- New PIN field -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilNewPin"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_new_pin"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvSetupPinSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNewPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberPassword"
            android:maxLength="6"
            android:textSize="20sp"
            android:letterSpacing="0.5"
            android:gravity="center" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Confirm PIN field -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilConfirmPin"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_confirm_pin"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tilNewPin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etConfirmPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberPassword"
            android:maxLength="6"
            android:textSize="20sp"
            android:letterSpacing="0.5"
            android:gravity="center" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- PIN length hint -->
    <TextView
        android:id="@+id/tvPinHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/pin_hint"
        android:textSize="12sp"
        android:textColor="#999999"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tilConfirmPin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Save button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSetupNext"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_save_pin"
        android:textSize="16sp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvPinHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Cancel button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSetupCancel"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_cancel"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnSetupNext"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>